// ============================================================
// ESP32 + A4988 chord player for Wokwi
// Uses working motor motion style from the chorus demo,
// while keeping a preset timing map for the full song.
//
// String order: {E, A, D, G, B, e}
// ============================================================

// ---------- ESP32 PIN MAP ----------
#define M1_STEP 18
#define M1_DIR  19

#define M2_STEP 25
#define M2_DIR  26

#define M3_STEP 27
#define M3_DIR  14

#define M4_STEP 12
#define M4_DIR  13

#define M5_STEP 32
#define M5_DIR  33

#define M6_STEP 23
#define M6_DIR  22

#define ENABLE_PIN 15   // A4988 enable is active LOW

const int STEP_PINS[6] = {M1_STEP, M2_STEP, M3_STEP, M4_STEP, M5_STEP, M6_STEP};
const int DIR_PINS[6]  = {M1_DIR,  M2_DIR,  M3_DIR,  M4_DIR,  M5_DIR,  M6_DIR};

// ---------- CHORDS ----------
// Order: {E, A, D, G, B, e}
int CHORD_C[6]     = {0, 3, 2, 0, 1, 0};
int CHORD_G[6]     = {3, 2, 0, 0, 0, 3};
int CHORD_Am[6]    = {0, 0, 2, 2, 1, 0};
int CHORD_Fmaj7[6] = {0, 0, 3, 2, 1, 0};

// ---------- FAST WOKWI TEST POSITIONS ----------
// Keep these small in simulation so the motion finishes quickly.
float fret_mm_pos[8] = {
  0.0,  // open
  1.0,  // fret 1
  2.0,  // fret 2
  3.0,  // fret 3
  4.0,  // fret 4
  5.0,  // fret 5
  6.0,  // fret 6
  7.0   // fret 7
};

const float STEPS_PER_REV = 200.0;
const float MICROSTEPPING = 16.0;
const float LEAD_MM = 8.0;
const float STEPS_PER_MM = (STEPS_PER_REV * MICROSTEPPING) / LEAD_MM; // 400

const float MIN_MM = 0.0;
const float MAX_MM = 7.0;
const int STEP_PULSE_US = 400;

float current_mm[6] = {0, 0, 0, 0, 0, 0};

// ---------- LOW LEVEL ----------
void pulseStepPin(int stepPin) {
  digitalWrite(stepPin, HIGH);
  delayMicroseconds(STEP_PULSE_US);
  digitalWrite(stepPin, LOW);
  delayMicroseconds(STEP_PULSE_US);
}

float clampMM(float value) {
  if (value < MIN_MM) return MIN_MM;
  if (value > MAX_MM) return MAX_MM;
  return value;
}

void moveMotorRelativeMM(int stepPin, int dirPin, float deltaMM) {
  long steps = lroundf(fabsf(deltaMM) * STEPS_PER_MM);
  if (steps <= 0) return;

  digitalWrite(dirPin, deltaMM >= 0 ? HIGH : LOW);

  for (long i = 0; i < steps; i++) {
    pulseStepPin(stepPin);
  }
}

void moveStringToMM(int stringNum, float targetMM) {
  if (stringNum < 1 || stringNum > 6) return;

  int idx = stringNum - 1;
  targetMM = clampMM(targetMM);

  float deltaMM = targetMM - current_mm[idx];
  moveMotorRelativeMM(STEP_PINS[idx], DIR_PINS[idx], deltaMM);
  current_mm[idx] = targetMM;
}

void goToFret(int stringNum, int fretNum) {
  if (stringNum < 1 || stringNum > 6) return;
  if (fretNum < 0 || fretNum > 7) return;

  moveStringToMM(stringNum, fret_mm_pos[fretNum]);
}

void releaseString(int stringNum) {
  moveStringToMM(stringNum, 0.0);
}

void releaseAllStrings() {
  for (int s = 1; s <= 6; s++) {
    releaseString(s);
  }
}

void playChord(int chord[6]) {
  for (int i = 0; i < 6; i++) {
    if (chord[i] == 0) {
      releaseString(i + 1);
    } else {
      goToFret(i + 1, chord[i]);
    }
  }
}

void printPositions() {
  Serial.print("Positions: ");
  for (int i = 0; i < 6; i++) {
    Serial.print(current_mm[i], 1);
    if (i < 5) Serial.print(", ");
  }
  Serial.println();
}

// ---------- SONG TIMING MAP ----------
struct SongEvent {
  uint32_t atMs;
  const char* lyric;
  int* chord;
  const char* chordName;
  uint32_t holdMs;
};

const int MAX_EVENTS = 256;
SongEvent events[MAX_EVENTS];
int eventCount = 0;
uint32_t songLengthMs = 0;

void addEvent(const char* lyric, int* chord, const char* chordName, uint32_t holdMs) {
  if (eventCount >= MAX_EVENTS) return;
  events[eventCount++] = {songLengthMs, lyric, chord, chordName, holdMs};
  songLengthMs += holdMs;
}

void addRest(uint32_t ms) {
  songLengthMs += ms;
}

