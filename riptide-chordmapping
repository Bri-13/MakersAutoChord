// ---------- PLAYBACK ----------
void singLine(const char* lyric, int chord[6], const char* chordName, int holdMs) {
  Serial.println("--------------------------------");
  Serial.print("Lyric: ");
  Serial.println(lyric);
  Serial.print("Chord: ");
  Serial.println(chordName);

  playChord(chord);
  printPositions();
  delay(holdMs);
}

void playEvent(const SongEvent& ev) {
  Serial.println("--------------------------------");
  Serial.print("Lyric: ");
  Serial.println(ev.lyric);
  Serial.print("Chord: ");
  Serial.println(ev.chordName);

  playChord(ev.chord);
  printPositions();
}

void playSongOnce() {
  uint32_t songStart = millis();

  for (int i = 0; i < eventCount; i++) {
    while ((millis() - songStart) < events[i].atMs) {
      delay(1);
    }
    playEvent(events[i]);
  }
}

// ---------- SETUP ----------
void setup() {
  Serial.begin(115200);

  pinMode(ENABLE_PIN, OUTPUT);
  digitalWrite(ENABLE_PIN, LOW); // enable A4988 drivers

  for (int i = 0; i < 6; i++) {
    pinMode(STEP_PINS[i], OUTPUT);
    pinMode(DIR_PINS[i], OUTPUT);
    digitalWrite(STEP_PINS[i], LOW);
    digitalWrite(DIR_PINS[i], LOW);
    current_mm[i] = 0.0;
  }

  buildSongMap();

  Serial.println("Riptide timing-map demo ready.");
  Serial.println("Homing strings to top hard stop...");
  releaseAllStrings();
  delay(1000);
  Serial.println("Open the Serial Monitor to see lyrics + chords.");
  Serial.println();
}

// ---------- LOOP ----------
void loop() {
  playSongOnce();

  Serial.println("=== Song complete ===");
  releaseAllStrings();
  delay(2000);
}
